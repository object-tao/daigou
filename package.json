{
  "name": "droppilot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "check:requirements": "node scripts/validate-requirements.mjs",
    "preview": "vite preview --host 0.0.0.0",
    "worker:dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply droppilot-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply droppilot-db --remote",
    "setup:production": "powershell -ExecutionPolicy Bypass -File scripts/setup-production.ps1"
  },
  "dependencies": {
    "hono": "^4.8.0",
    "lucide-react": "^0.468.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260617.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "wrangler": "^4.23.0"
  }
}
